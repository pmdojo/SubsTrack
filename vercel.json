{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd expo && npm install && npx expo export --platform web",
  "outputDirectory": "expo/dist",
  "installCommand": "echo 'skip root install'",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
